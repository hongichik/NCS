# =============================================================================
# NCS workspace conventions
# - Data/  : KHÔNG commit (dataset, artifact, checkpoint lớn)
# - Log/     : log quá trình (full cmd output) — ĐƯỢC commit
# - LogMins/ : kết quả cuối cùng — ĐƯỢC commit
# =============================================================================

# --- Centralized data (never push) ---
Data/
.cursor/
# Stray .log outside Log/ and LogMins/ (both trees are tracked)
*.log
!Log/
!Log/**
!LogMins/
!LogMins/**

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Virtual environments ---
venv/
ENV/
env/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# --- Jupyter Notebook ---
.ipynb_checkpoints/
